# PostgreSQL connection string used by Prisma.
# Example local database:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dayrank?schema=public"

# Auth.js / NextAuth secret. Generate one with: npx auth secret
AUTH_SECRET="replace-with-a-long-random-secret"

# Public URL of the application.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Necesarias solo al subir fotos de publicaciones a Cloudinary.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Opcional: carpeta de Cloudinary para las fotos de publicaciones.
CLOUDINARY_UPLOAD_FOLDER="dayrank/posts"
