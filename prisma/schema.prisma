generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String         @id @default(cuid())
  name                  String
  username              String         @unique
  email                 String         @unique
  emailVerified         DateTime?
  image                 String?
  bio                   String?        @db.VarChar(280)
  passwordHash          String
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  accounts              Account[]
  sessions              Session[]
  settings              UserSettings?
  posts                 Post[]
  likes                 Like[]
  comments              Comment[]
  sentFriendships       Friendship[]   @relation("FriendshipRequester")
  receivedFriendships   Friendship[]   @relation("FriendshipReceiver")
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsActed    Notification[] @relation("NotificationActor")
  blocksCreated         UserBlock[]    @relation("UserBlocker")
  blocksReceived        UserBlock[]    @relation("UserBlocked")

  @@index([name])
  @@index([username])
}

model Post {
  id            String         @id @default(cuid())
  userId        String
  date          DateTime       @db.Date
  rating        Decimal        @db.Decimal(4, 2)
  title         String         @db.VarChar(120)
  description   String?        @db.Text
  mood          PostMood?
  visibility    PostVisibility @default(PRIVATE)
  photoUrl      String?        @db.VarChar(2048)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes         Like[]
  comments      Comment[]
  notifications Notification[]

  @@unique([userId, date])
  @@index([date])
  @@index([visibility])
  @@index([visibility, date, createdAt])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([postId, createdAt])
  @@index([userId])
}

model Comment {
  id            String         @id @default(cuid())
  content       String         @db.VarChar(500)
  userId        String
  postId        String
  parentId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post          Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent        Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]      @relation("CommentReplies")
  notifications Notification[]

  @@index([postId])
  @@index([postId, parentId, createdAt])
  @@index([parentId])
  @@index([userId])
  @@index([createdAt])
}

model Friendship {
  id            String           @id @default(cuid())
  requesterId   String
  receiverId    String
  pairKey       String           @unique
  status        FriendshipStatus @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  requester     User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver      User             @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@unique([requesterId, receiverId])
  @@index([requesterId, status])
  @@index([receiverId, status])
  @@index([status])
}

model Notification {
  id           String           @id @default(cuid())
  recipientId  String
  actorId      String
  type         NotificationType
  friendshipId String?
  postId       String?
  commentId    String?
  readAt       DateTime?
  createdAt    DateTime         @default(now())
  recipient    User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor        User             @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  friendship   Friendship?      @relation(fields: [friendshipId], references: [id], onDelete: SetNull)
  post         Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment      Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt, createdAt])
  @@index([actorId])
  @@index([friendshipId])
  @@index([postId])
  @@index([commentId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocker   User     @relation("UserBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("UserBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model UserSettings {
  id        String    @id @default(cuid())
  userId    String    @unique
  theme     ThemeMode @default(LIGHT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum ThemeMode {
  LIGHT
  DARK
  SYSTEM
}

enum PostMood {
  HAPPY
  TIRED
  PRODUCTIVE
  STRESSED
  CALM
  MOTIVATED
  BAD_DAY
  NORMAL_DAY
}

enum PostVisibility {
  PRIVATE
  FRIENDS
  PUBLIC
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum NotificationType {
  FRIEND_REQUEST_RECEIVED
  FRIEND_REQUEST_ACCEPTED
  POST_LIKED
  POST_COMMENTED
  COMMENT_REPLIED
  USER_MENTIONED
}
